<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Reincrew AI Owner</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap" rel="stylesheet">
</head>
<body class="selection:bg-indigo-500 selection:text-white">
    <header class="fixed top-0 left-0 right-0 z-50 px-8 py-6 flex justify-between items-center bg-transparent backdrop-blur-md border-b border-white/10">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-indigo-600 rounded-xl flex items-center justify-center shadow-lg shadow-indigo-600/20">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <span class="text-xl font-black tracking-tighter text-slate-900">REINCREW <span class="text-indigo-600 underline decoration-indigo-200 underline-offset-4">OWNER</span></span>
        </div>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="flex items-center gap-6">
                <span class="text-xs font-bold opacity-60 uppercase tracking-widest">Logged in as @User.Identity.Name</span>
                <form method="post" asp-page="/Login" asp-page-handler="Logout">
                    <button type="submit" class="text-xs font-black uppercase tracking-widest bg-white/10 hover:bg-white/20 px-4 py-2 rounded-lg transition-all">Logout</button>
                </form>
            </div>
        }
    </header>

    <main role="main" class="pt-32 pb-20">
        @RenderBody()
    </main>

    <footer class="py-12 px-8 border-t border-slate-200/50 text-slate-400 text-[10px] font-bold uppercase tracking-[0.2em] flex justify-between items-center bg-white/30 backdrop-blur-sm">
        <p>&copy; 2026 Reincrew AI. <span class="text-slate-900">Standalone Platform Management</span></p>
        <div class="flex gap-6 items-center">
            <span class="flex items-center gap-2"><div class="w-2 h-2 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)]"></div> Network Active</span>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
