@page
@model AppOwnerPortal.Pages.LoginModel
@{
    ViewData["Title"] = "App Owner Login";
    Layout = "_Layout";
}

<div class="flex items-center justify-center min-h-[60vh] animate-fade-in">
    <div class="w-full max-w-sm glass-panel p-10 rounded-[2.5rem] relative overflow-hidden group">
        {/* Subtle internal glow */}
        <div class="absolute -top-24 -right-24 w-48 h-48 bg-indigo-600/5 rounded-full blur-3xl group-hover:bg-indigo-600/10 transition-colors"></div>
        
        <div class="text-center mb-10 relative z-10">
            <div class="w-16 h-16 bg-indigo-600/10 rounded-2xl flex items-center justify-center mx-auto mb-6 border border-indigo-600/20 group-hover:scale-110 transition-transform duration-500">
                <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 00-2 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
            </div>
            <h2 class="text-2xl font-black tracking-tighter text-slate-900">App Owner Login</h2>
            <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mt-1 opacity-60">Reicrew Intelligence Node</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="bg-red-50/50 text-red-500 p-4 rounded-2xl text-[10px] font-black uppercase tracking-widest border border-red-100 mb-6 text-center animate-fade-in">
                @Model.ErrorMessage
            </div>
        }

        <form method="post" class="space-y-5 relative z-10">
            <div>
                <label class="block text-[9px] font-black text-slate-400 uppercase tracking-[0.2em] mb-2 px-1">Username</label>
                <input asp-for="Username" required class="w-full h-14 bg-white/50 border border-slate-200/50 rounded-2xl px-6 text-sm outline-none focus:border-indigo-500 focus:bg-white transition-all font-medium placeholder:text-slate-300 shadow-sm" placeholder="owner" />
            </div>
            <div>
                <label class="block text-[9px] font-black text-slate-400 uppercase tracking-[0.2em] mb-2 px-1">Access Protocol</label>
                <input asp-for="Password" type="password" required class="w-full h-14 bg-white/50 border border-slate-200/50 rounded-2xl px-6 text-sm outline-none focus:border-indigo-500 focus:bg-white transition-all font-medium placeholder:text-slate-300 shadow-sm" placeholder="••••••••" />
            </div>

            <button type="submit" class="w-full h-14 bg-indigo-600 hover:bg-indigo-700 text-white font-black rounded-2xl shadow-xl shadow-indigo-600/20 transition-all text-[10px] uppercase tracking-[0.2em] mt-8 hover:-translate-y-0.5 active:translate-y-0">
                Authenticate Node
            </button>
        </form>
    </div>
</div>
